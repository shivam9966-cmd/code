    ROUND(((SUM(CASE WHEN "scenario"='2+10' THEN COALESCE("amount",0) ELSE 0 END)-SUM(CASE WHEN "scenario"='1+11' THEN COALESCE("amount",0) ELSE 0 END))/NULLIF(SUM(CASE WHEN "scenario"='1+11' THEN COALESCE("amount",0) ELSE 0 END),0)*100)::numeric,2) AS variance_pct
    FROM finance.forecast_data_updated
