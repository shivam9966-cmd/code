SELECT 'summary' AS row_type, s."attrition_description", s."ruc_risk_attrition",
s.latest, s.previous, s.variance, s.variance_pct,
NULL::text AS "EntityName", NULL::numeric AS rnk
FROM summary s
UNION ALL
SELECT 'customer', c."attrition_description", c."ruc_risk_attrition",
NULL::numeric, NULL::numeric, c.variance, NULL::numeric,
c."EntityName", CAST(c.rnk AS numeric)
