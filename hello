def build_customer_insights(df_desc: pd.DataFrame) -> dict:
    customer_insights = {"top_clients": [], "risk_clients": []}

    if df_desc is None or df_desc.empty:
        return customer_insights

    if "entity_name" not in df_desc.columns:
        return customer_insights

    df_desc = df_desc.copy()

    value_col = None
    for col in ["variance", "revenue_M"]:
        if col in df_desc.columns:
            value_col = col
            break

    if value_col is None:
        return customer_insights

    df_desc[value_col] = pd.to_numeric(df_desc[value_col], errors="coerce").fillna(0)

    top_clients = (
        df_desc[~df_desc["entity_name"].isin(EXCLUDED_CLIENTS)]
        .groupby("entity_name")[value_col]
        .sum()
        .reset_index()
        .rename(columns={value_col: "variance"})
        .assign(variance=lambda x: x["variance"].round(1))
        .sort_values("variance", ascending=False, key=abs)
        .head(5)
    )
    customer_insights["top_clients"] = top_clients.to_dict(orient="records")

    if "ruc_risk" in df_desc.columns and "l9_account" in df_desc.columns:
        risk_df = df_desc[df_desc["ruc_risk"].isin(["RISK-ID", "RISK-UNID"])].copy()

        if not risk_df.empty:
            risk_clients = (
                risk_df[~risk_df["entity_name"].isin(EXCLUDED_CLIENTS)]
                .groupby("entity_name")[value_col]
                .sum()
                .reset_index()
                .assign(**{value_col: lambda x: x[value_col].round(1)})
                .sort_values(value_col, ascending=False, key=abs)
                .head(3)
            )

            risk_result = []
            for _, row in risk_clients.iterrows():
                entity = row["entity_name"]
                l9_breakdown = (
                    risk_df[risk_df["entity_name"] == entity]
                    .groupby("l9_account")[value_col]
                    .sum()
                    .reset_index()
                    .assign(**{value_col: lambda x: x[value_col].round(1)})
                    .sort_values(value_col, ascending=False, key=abs)
                    .head(2)
                    .to_dict(orient="records")
                )
                risk_result.append({
                    "entity_name": entity,
                    "variance": round(float(row[value_col]), 1),
                    "l9_accounts": l9_breakdown
                })

            customer_insights["risk_clients"] = risk_result

    print("=== CUSTOMER INSIGHTS ===")
    print(json.dumps(customer_insights, indent=2))

    return customer_insights


def node_build_answer(state: SQLState):
    emit_progress("final_answer", "running")

    if state["is_greeting_or_business"] == "greetings":
        greetings_ans = casual_query_response(state.get("user_query"))
        emit_progress("final_answer", "completed")
        return {
            "waterfall_json": [],
            "chart_type": [],
            "chart_payload": [],
            "answer": greetings_ans,
            "embedding_str": [],
            "history": []
        }

    if state["sql_decision"] == "retry_sql_counter" or state["desc_sql_decision"] == "retry_desc_sql_counter":
        failure_ans = dataframe_failure_response(state.get("user_query"), state["input_file"])
        emit_progress("final_answer", "completed")
        return {
            "waterfall_json": [],
            "chart_type": [],
            "chart_payload": [],
            "answer": failure_ans,
            "embedding_str": [],
            "history": []
        }

    df_json = state.get("_df")
    df_desc_json = state.get("_df_desc")

    df = json_list_to_df(df_json) if df_json else None
    df_desc = json_list_to_df(df_desc_json) if df_desc_json else None

    # Generate data.json for frontend
    df_desc_insights = generate_commentary_package(df_desc)
    with open("data.json", "w", encoding="utf-8") as f:
        json.dump(df_desc_insights, f, indent=4)

    print("=== DATA.JSON FINAL KEYS ===", list(df_desc_insights.keys()))
    print("=== VARIANCE_DRIVERS KEYS ===", list(df_desc_insights.get("variance_drivers", {}).keys()))

    print("=== DF_DESC COLUMNS ===")
    if df_desc is not None:
        print(df_desc.columns.tolist())
        print(df_desc.head(5).to_string())
    else:
        print("df_desc is None")

    # Build customer insights in Python
    customer_insights = build_customer_insights(df_desc)

    # Trim df_desc to top 100 rows for LLM
    if df_desc is not None and len(df_desc) > 0:
        sort_col = None
        for col in ["variance", "revenue_M", "2+10", "1+11"]:
            if col in df_desc.columns:
                sort_col = col
                break

        if sort_col:
            df_desc[sort_col] = pd.to_numeric(df_desc[sort_col], errors="coerce").fillna(0)

            if sort_col == "variance":
                top_positive = (
                    df_desc[df_desc[sort_col] > 0]
                    .sort_values(by=sort_col, ascending=False)
                    .head(50)
                )
                top_negative = (
                    df_desc[df_desc[sort_col] < 0]
                    .sort_values(by=sort_col, ascending=True)
                    .head(50)
                )
                df_desc = pd.concat([top_positive, top_negative], ignore_index=True)
            else:
                df_desc = df_desc.sort_values(by=sort_col, ascending=False).head(100)

            df_desc = df_desc.reset_index(drop=True)

    # Build LLM payload — always pass both table_rows and customer_insights
    if df_desc is not None:
        llm_desc_payload = {
            "table_rows": df_desc.head(100).to_dict(orient="records"),
            "customer_insights": customer_insights
        }
    else:
        llm_desc_payload = {
            "table_rows": [],
            "customer_insights": customer_insights
        }

    # Guard: no data
    if df is None or df.empty:
        emit_progress("final_answer", "completed")
        ans = (
            "I couldn't find the data. "
            "Please check the selected report, reframe the query and try again!"
        )
        return {
            "waterfall_json": [],
            "answer": ans,
            "embedding_str": [],
            "history": []
        }

    # Chart handling
    chart_json = json.loads(state.get("chart_payload") or "{}")
    waterfall_json = chart_json if chart_json.get("type") == "waterfall" else []

    applied = state.get("applied_defaults") or []
    if applied:
        applied_defaults_note = (
            "<p><em>Note: I applied these defaults — "
            + "; ".join(applied)
            + ".</em></p>"
        )
    else:
        applied_defaults_note = ""

    answer, embedding_str = to_human_readable(
        state.get("user_query"),
        state.get("question"),
        state.get("final_sql"),
        df,
        llm_desc_payload,
        state.get("input_file"),
        applied_defaults_note
    )

    print("=== ANSWER LENGTH ===", len(answer) if answer else 0)
    print("=== ANSWER FIRST 500 ===", answer[:500] if answer else "EMPTY")

    emit_progress("final_answer", "completed")

    return {
        "waterfall_json": waterfall_json,
        "answer": answer,
        "embedding_str": embedding_str,
        "history": [{"q": state.get("question"), "a": answer}]
    }
