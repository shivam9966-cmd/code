SECTION 3: DRIVERS QUERY (HIGHEST PRIORITY)
═══════════════════════════════════════════
Triggers: "explain the drivers","drivers of recurring revenue","drivers of revenue growth",
"explain components contributing","contributing to change","explain the change",
"what is driving","breakdown of change","RUC and new sales","organic revenue and new sales",
"organic revenue (RUC) and new sales (risk)","explain 2+10 vs 1+11","what changed between"

NEVER trigger for plain "what is the variance between X and Y" without driver keywords.

MANDATORY: Generate ONLY the CTE below. Start with WITH summary AS (.
Include "Year" in BOTH CTEs. Include "l8_account" filter if user mentions recurring.

WITH summary AS (
    SELECT "attrition_description","ruc_risk",
    ROUND((SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS latest,
    ROUND((SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS previous,
    ROUND(((SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)-SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2) AS variance,
    ROUND(((SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)-SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END))/NULLIF(SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END),0)*100)::numeric,2) AS variance_pct
    FROM finance.forecast_data_new WHERE "Year"=[Y] AND "l8_account"='Recurring Revenue'
    GROUP BY "attrition_description","ruc_risk"
),
customer_ranked AS (
    SELECT "attrition_description","ruc_risk","entity_name",
    ROUND(((SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)-SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2) AS variance,
    RANK() OVER (PARTITION BY "attrition_description","ruc_risk"
        ORDER BY ABS(SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)-SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END)) DESC) AS rnk
    FROM finance.forecast_data_new WHERE "Year"=[Y] AND "l8_account"='Recurring Revenue'
    GROUP BY "attrition_description","ruc_risk","entity_name"
)
SELECT * FROM (
    SELECT 'summary' AS row_type, s."attrition_description", s."ruc_risk", s.latest, s.previous, s.variance, s.variance_pct, NULL::text AS entity_name, NULL::numeric AS rnk FROM summary s
    UNION ALL
    SELECT 'customer', c."attrition_description", c."ruc_risk", NULL::numeric, NULL::numeric, c.variance, NULL::numeric, c."entity_name", CAST(c.rnk AS numeric) FROM customer_ranked c WHERE c.rnk<=5
    UNION ALL
    SELECT 'total_row', NULL::text, NULL::text,
    ROUND((SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2),
    ROUND((SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2),
    ROUND(((SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)-SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2),
    ROUND(((SUM(CASE WHEN "version"=[V1] THEN COALESCE("amount",0) ELSE 0 END)-SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END))/NULLIF(SUM(CASE WHEN "version"=[V2] THEN COALESCE("amount",0) ELSE 0 END),0)*100)::numeric,2),
    NULL::text, NULL::numeric
    FROM finance.forecast_data_new WHERE "Year"=[Y] AND "l8_account"='Recurring Revenue'
) drivers_result
ORDER BY CASE row_type WHEN 'summary' THEN 0 WHEN 'customer' THEN 1 ELSE 2 END,
CASE "ruc_risk" WHEN 'RUC' THEN 1 WHEN 'Risk ID' THEN 2 WHEN 'Risk UID' THEN 3 ELSE 4 END,
"attrition_description", rnk

Substitute [V1]=latest version, [V2]=prior version, [Y]=year from user question or dynamic subqueries.

