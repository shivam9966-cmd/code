import pandas as pd
from typing import Any, Dict

MONTH_ORDER = {
    'Jan': 1, 'Feb': 2, 'Mar': 3, 'Apr': 4,
    'May': 5, 'Jun': 6, 'Jul': 7, 'Aug': 8,
    'Sep': 9, 'Oct': 10, 'Nov': 11, 'Dec': 12,
    'Q1': 13, 'Q2': 14, 'Q3': 15, 'Q4': 16
}

# Category display order for waterfall bars
CATEGORY_ORDER = [
    'RUC', 'Risk ID', 'Risk UID',
    'attrition provision', 'Known attrition', 'Specific attrition'
]

# Display labels for categories
DISPLAY_LABELS = {
    'RUC':                 'RUC',
    'Risk ID':             'Risk ID',
    'Risk UID':            'Risk UID',
    'attrition provision': 'Attrition Provision',
    'Known attrition':     'Known Attrition',
    'Specific attrition':  'Specific Attrition',
}


def detect_chart_type(question: str) -> str:
    q = question.lower()
    chart_type = "bar"  # default

    # ── ATTRITION CHANGE — must be checked FIRST before drivers waterfall ──
    # Prompt rule: "change in attrition", "explain attrition change",
    # "attrition from 2+10 vs 1+11", "attrition difference" -> ALWAYS BAR CHART
    is_attrition_change = (
        any(word in q for word in [
            "attrition", "change in attrition",
            "attrition change", "explain attrition"
        ])
        and any(word in q for word in [
            "vs", "versus", "compare", "change",
            "explain", "difference", "2+10", "1+11"
        ])
    )
    if is_attrition_change:
        return "bar"

    # ── DRIVERS — waterfall (only when NOT attrition change) ──
    if any(word in q for word in [
        "drivers", "components contributing", "contributing to change",
        "explain the change", "ruc and new sales", "organic revenue",
        "explain drivers", "what changed", "what is driving"
    ]):
        return "waterfall"

    if any(word in q for word in ["distribution", "share", "split", "composition", "%"]):
        chart_type = "pie"

    if any(word in q for word in [
        "trend", "over time", "monthly", "quarterly",
        "quarter", "q1", "q2", "q3", "q4", "by quarter"
    ]):
        chart_type = "line"

    if any(word in q for word in ["top", "bottom", "highest", "lowest", "breakdown"]):
        chart_type = "bar"

    # ── CLIENT/ENTITY grouping always bar ──
    # Fixes: Q1 + client-wise view incorrectly getting line chart
    if any(word in q for word in [
        "client", "entity", "customer", "account",
        "client wise", "clientwise", "client-wise"
    ]):
        chart_type = "bar"

    # Explicit waterfall only when user says waterfall/bridge/walk
    has_waterfall_word = any(word in q for word in ["waterfall", "bridge", "walk"])
    has_breakdown = any(word in q for word in [
        "by l3", "by l4", "by l5", "by l6", "by l7", "by l8",
        "by client", "by product", "by account", "summary", "breakdown", "level"
    ])
    is_comparison = any(word in q for word in [
        "vs", "versus", "compare", "attrition",
        "components", "contributing", "change in", "explain"
    ])

    if has_waterfall_word and not has_breakdown and not is_comparison:
        chart_type = "waterfall"

    return chart_type


def _safe_float(x: Any) -> float:
    try:
        return float(x)
    except Exception:
        return 0.0


def _sort_by_month(df: pd.DataFrame, col: str) -> pd.DataFrame:
    """Sort dataframe by month/quarter order if column contains month names."""
    if df[col].astype(str).str.strip().isin(MONTH_ORDER.keys()).any():
        df = df.copy()
        df["_sort_key"] = df[col].astype(str).str.strip().map(
            lambda x: MONTH_ORDER.get(x, 999)
        )
        df = df.sort_values("_sort_key").drop(columns=["_sort_key"])
    return df


def _is_drivers_query(df: pd.DataFrame) -> bool:
    """Detect if this is a drivers query result (has row_type + attrition + ruc_risk columns)."""
    if df is None or df.empty:
        return False
    return (
        'row_type' in df.columns and
        'attrition_description' in df.columns and
        'ruc_risk' in df.columns
    )


def build_waterfall_json(df: pd.DataFrame) -> Dict[str, Any]:
    """
    Build waterfall chart for drivers query.
    Structure:
      Bar 1: Prior (1+11) total — solid bar from base=0
      Bars 2-7: Floating variance bars for each category
      Bar 8: Latest (2+10) total — solid bar from base=0
    """
    empty = {"type": "waterfall", "columns": [], "data": [], "base": [], "is_total": [], "is_positive": []}

    if df is None or df.empty:
        return empty

    # Separate row types
    summary_df = df[df['row_type'] == 'summary'].copy()
    total_row  = df[df['row_type'] == 'total_row']

    if summary_df.empty:
        return empty

    # Build Description label for each summary row
    # attrition rows: use attrition_description value
    # blank attrition rows: use ruc_risk value
    summary_df['_label'] = summary_df.apply(
        lambda r: r['attrition_description']
        if pd.notna(r['attrition_description']) and str(r['attrition_description']).strip() != ''
        else r['ruc_risk'],
        axis=1
    )

    # Get variance column (not pct)
    variance_col = next(
        (c for c in summary_df.columns
         if 'variance' in c.lower() and 'pct' not in c.lower()
         and c not in ('row_type', 'ruc_risk', 'attrition_description', 'entity_name')),
        None
    )
    if variance_col is None:
        return empty

    # Get prior and latest totals from total_row
    prior_col  = next((c for c in summary_df.columns if 'prior' in c.lower()), None)
    latest_col = next((c for c in summary_df.columns if 'latest' in c.lower()), None)

    if not total_row.empty and prior_col and latest_col:
        prior_total  = _safe_float(total_row[prior_col].iloc[0])
        latest_total = _safe_float(total_row[latest_col].iloc[0])
    elif prior_col and latest_col:
        # Fallback: sum all summary rows
        prior_total  = _safe_float(summary_df[prior_col].sum())
        latest_total = _safe_float(summary_df[latest_col].sum())
    else:
        return empty

    # Sort summary rows by CATEGORY_ORDER
    summary_df['_order'] = summary_df['_label'].apply(
        lambda x: CATEGORY_ORDER.index(x) if x in CATEGORY_ORDER else 99
    )
    summary_df = summary_df.sort_values('_order')

    # Build waterfall bars
    columns     = []
    data        = []
    base        = []
    is_total    = []
    is_positive = []

    # Bar 1: Prior (1+11) — solid bar from 0
    columns.append('Prior (1+11)')
    data.append(round(prior_total, 2))
    base.append(0)
    is_total.append(True)
    is_positive.append(True)

    # Bars 2-7: Floating variance bars
    running = prior_total
    for _, row in summary_df.iterrows():
        v     = _safe_float(row[variance_col])
        label = DISPLAY_LABELS.get(str(row['_label']), str(row['_label']))
        columns.append(label)
        data.append(round(abs(v), 2))
        base.append(round(running + v, 2) if v < 0 else round(running, 2))
        is_total.append(False)
        is_positive.append(v >= 0)
        running = round(running + v, 2)

    # Bar 8: Latest (2+10) — solid bar from 0, value = full latest total
    columns.append('Latest (2+10)')
    data.append(round(latest_total, 2))
    base.append(0)
    is_total.append(True)
    is_positive.append(latest_total >= prior_total)

    return {
        "type":        "waterfall",
        "columns":     columns,
        "data":        data,
        "base":        base,
        "is_total":    is_total,
        "is_positive": is_positive
    }


def build_waterfall_json_generic(df_desc: pd.DataFrame) -> Dict[str, Any]:
    """
    Generic waterfall for non-drivers queries (explicit waterfall/bridge/walk keyword).
    Uses last numeric column as variance values.
    """
    if df_desc is None or df_desc.empty:
        return {"type": "waterfall", "columns": [], "data": []}

    label_col    = df_desc.columns[0]
    numeric_cols = []
    for c in df_desc.columns[1:]:
        s = pd.to_numeric(df_desc[c], errors="coerce")
        if s.notna().any():
            numeric_cols.append(c)
    if not numeric_cols:
        return {"type": "waterfall", "columns": [], "data": []}

    variance_col = numeric_cols[-1]
    df = df_desc.copy()
    df[variance_col] = pd.to_numeric(df[variance_col], errors="coerce").fillna(0.0)
    df = df.sort_values(by=variance_col, ascending=False)
    top        = df.head(9)
    others_sum = float(df.iloc[9:][variance_col].sum()) if len(df) > 9 else 0.0
    labels     = top[label_col].fillna("").astype(str).tolist()
    values     = top[variance_col].tolist()
    if len(df) > 9:
        labels.append("others")
        values.append(others_sum)
    return {"type": "waterfall", "columns": labels, "data": values}


def build_pie_json(df: pd.DataFrame) -> Dict[str, Any]:
    if df is None or df.empty:
        return {"type": "pie", "columns": [], "data": []}

    category_col = None
    for c in df.columns:
        if not pd.api.types.is_numeric_dtype(df[c]):
            category_col = c
            break

    numeric_cols = [c for c in df.columns if pd.api.types.is_numeric_dtype(df[c])]
    if not numeric_cols or category_col is None:
        return {"type": "pie", "columns": [], "data": []}

    value_col = numeric_cols[0]
    return {
        "type":    "pie",
        "columns": df[category_col].astype(str).tolist(),
        "data":    [_safe_float(v) for v in df[value_col].tolist()]
    }


def build_bar_json(df: pd.DataFrame) -> Dict[str, Any]:
    if df is None or df.empty:
        return {"type": "bar", "columns": [], "data": []}

    SKIP_COLS = {'row_type', 'sort_key', 'rnk', 'row_number', 'attrition_description', 'ruc_risk'}

    # Filter summary rows only if row_type column exists
    if 'row_type' in df.columns:
        df = df[df['row_type'] == 'summary'].copy()

    # Build Description column for attrition+ruc_risk queries
    if 'attrition_description' in df.columns and 'ruc_risk' in df.columns:
        df['Description'] = df.apply(
            lambda r: r['attrition_description']
            if pd.notna(r['attrition_description']) and str(r['attrition_description']).strip() != ''
            else r['ruc_risk'],
            axis=1
        )
        x_col = 'Description'
    else:
        x_col = None
        for c in df.columns:
            if not pd.api.types.is_numeric_dtype(df[c]) and c not in SKIP_COLS:
                x_col = c
                break

    numeric_cols = [c for c in df.columns if pd.api.types.is_numeric_dtype(df[c]) and c not in SKIP_COLS]
    if not numeric_cols or x_col is None:
        return {"type": "bar", "columns": [], "data": []}

    # Prefer variance column (not pct)
    y_col = next(
        (c for c in numeric_cols if 'variance' in c.lower() and 'pct' not in c.lower()),
        numeric_cols[0]
    )

    # Remove Total row from chart
    df = df[df[x_col].astype(str).str.strip() != 'Total']

    return {
        "type":    "bar",
        "columns": df[x_col].astype(str).tolist(),
        "data":    [_safe_float(v) for v in df[y_col].tolist()]
    }


def build_line_json(df: pd.DataFrame) -> Dict[str, Any]:
    if df is None or df.empty:
        return {"type": "line", "columns": [], "data": []}

    label_col = None
    for col in ['period', 'Period', 'Month', 'month', 'quarter', 'Quarter']:
        if col in df.columns:
            label_col = col
            break

    EXCLUDE   = {'sort_order', 'sort_key', '_sort_key', 'row_type', 'type', 'year', 'Year', 'month_num'}
    value_col = None
    for col in df.select_dtypes(include='number').columns:
        if col.lower() not in {e.lower() for e in EXCLUDE}:
            value_col = col
            break

    if label_col is None or value_col is None:
        return {"type": "line", "columns": [], "data": []}

    # Remove Total row
    df = df[df[label_col].astype(str).str.strip() != 'Total']

    return {
        'type':    'line',
        'columns': df[label_col].astype(str).tolist(),
        'data':    [_safe_float(v) for v in df[value_col].tolist()]
    }


def build_chart_payload(chart_type: str, df: pd.DataFrame, df_desc: pd.DataFrame) -> Dict[str, Any]:
    try:
        # ── DEBUG: log incoming state ────────────────────────────────────────
        print(f"[chart_router] chart_type={chart_type} | "
              f"df_shape={df.shape if df is not None else None} | "
              f"df_cols={list(df.columns) if df is not None else None} | "
              f"_is_drivers_query={_is_drivers_query(df)}")

        # ── Auto-detect drivers query from DataFrame structure ──────────────
        # Only upgrade to waterfall if chart_type is NOT already forced to bar.
        # This respects the attrition change rule (bar override from detect_chart_type).
        if _is_drivers_query(df) and chart_type != "bar":
            chart_type = "waterfall"

        # ── Remove Total rows for non-waterfall charts ───────────────────────
        if chart_type != "waterfall" and df is not None:
            for col in df.columns:
                if df[col].dtype == object:
                    df = df[df[col].astype(str).str.strip() != 'Total']
                    break

        # ── Month code conversion ────────────────────────────────────────────
        MONTH_CODE_MAP = {
            'JANF26': 'Jan', 'FEBF26': 'Feb', 'MARF26': 'Mar', 'APRF26': 'Apr',
            'MAYF26': 'May', 'JUNF26': 'Jun', 'JULF26': 'Jul', 'AUGF26': 'Aug',
            'SEPF26': 'Sep', 'OCTF26': 'Oct', 'NOVF26': 'Nov', 'DECF26': 'Dec',
            'JANF25': 'Jan', 'FEBF25': 'Feb', 'MARF25': 'Mar', 'APRF25': 'Apr',
            'MAYF25': 'May', 'JUNF25': 'Jun', 'JULF25': 'Jul', 'AUGF25': 'Aug',
            'SEPF25': 'Sep', 'OCTF25': 'Oct', 'NOVF25': 'Nov', 'DECF25': 'Dec',
        }
        if df is not None and 'month_code' in df.columns:
            df['Month'] = df['month_code'].map(MONTH_CODE_MAP).fillna(df['month_code'])

        # ── Sort by month/quarter if applicable ──────────────────────────────
        if df is not None and chart_type != "waterfall":
            for col in ['period', 'Month', 'month', 'quarter', 'Quarter']:
                if col in df.columns:
                    df = _sort_by_month(df, col)
                    break

        # ── Route to correct builder ─────────────────────────────────────────
        if chart_type == "waterfall":
            # Priority 1: df is a valid structured drivers query result
            if _is_drivers_query(df):
                return build_waterfall_json(df)
            # Priority 2: df is missing/incomplete but df_desc is a valid drivers result
            # This handles the case where chart_type="waterfall" was detected from the
            # question but df was not passed correctly into build_chart_payload
            if df_desc is not None and not df_desc.empty and _is_drivers_query(df_desc):
                print("[chart_router] WARNING: df missing drivers columns — falling back to df_desc for waterfall")
                return build_waterfall_json(df_desc)
            # Priority 3: Generic waterfall (explicit waterfall/bridge/walk keyword questions)
            return build_waterfall_json_generic(df_desc)

        if chart_type == "pie":
            return build_pie_json(df)

        if chart_type == "bar":
            return build_bar_json(df)

        if chart_type == "line":
            return build_line_json(df)

        print(f"[chart_router] Unhandled chart_type: {chart_type}")
        return {"type": chart_type}

    except Exception as e:
        print(f"[chart_router] Chart build failed: {repr(e)}")
        return {"type": "bar", "columns": [], "data": []}
