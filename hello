When user says "drivers of recurring revenue growth by organic revenue (RUC) and new sales (risk)"
or "explain drivers by RUC and risk":
-> NEVER filter on a single ruc_risk value. Fetch ALL ruc_risk values: 'RUC', 'Risk ID', 'Risk UID'.
-> GROUP BY "attrition_description", "ruc_risk" together.
-> NEVER apply LIMIT — fetch all combinations.
-> NEVER filter out NULL attrition_description — blank attrition rows contain Risk ID and Risk UID data.
-> Do NOT add "attrition_description" IS NOT NULL filter for this query.
-> Use CTE to fetch both summary rows AND top 5 customer breakdown in one query.
-> row_type = 'summary' for main rows, row_type = 'customer' for customer breakdown rows, row_type = 'total_row' for grand total.
-> SQL MUST start with: WITH summary AS (
-> NEVER omit the WITH keyword or the CTE name.
-> ALWAYS include "Year" = 2026 in BOTH CTEs WHERE clause.
CORRECT SQL:
WITH summary AS (
    SELECT "attrition_description", "ruc_risk",
    ROUND((SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS latest_forecast,
    ROUND((SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS prior_forecast,
    ROUND(((SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END) - SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2) AS variance,
    ROUND(((SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END) - SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END)) / NULLIF(SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END),0) * 100)::numeric,2) AS variance_pct
    FROM finance.forecast_data_new
    WHERE "Year" = 2026 AND "l8_account" = 'Recurring Revenue'
    GROUP BY "attrition_description", "ruc_risk"
),
customer_ranked AS (
    SELECT "attrition_description", "ruc_risk", "entity_name",
    ROUND(((SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END) - SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2) AS variance,
    RANK() OVER (
        PARTITION BY "attrition_description", "ruc_risk"
        ORDER BY ABS(SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END) - SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END)) DESC
    ) AS rnk
    FROM finance.forecast_data_new
    WHERE "Year" = 2026 AND "l8_account" = 'Recurring Revenue'
    GROUP BY "attrition_description", "ruc_risk", "entity_name"
)
SELECT 'summary' AS row_type, s."attrition_description", s."ruc_risk",
s.latest_forecast, s.prior_forecast, s.variance, s.variance_pct,
NULL AS entity_name, NULL AS rnk
FROM summary s
UNION ALL
SELECT 'customer', c."attrition_description", c."ruc_risk",
NULL, NULL, c.variance, NULL,
c."entity_name", CAST(c.rnk AS numeric)
FROM customer_ranked c WHERE c.rnk <= 5
UNION ALL
SELECT 'total_row', NULL, NULL,
ROUND((SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2),
ROUND((SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2),
ROUND(((SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END) - SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2),
ROUND(((SUM(CASE WHEN "version" = '2+10' THEN COALESCE("amount",0) ELSE 0 END) - SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END)) / NULLIF(SUM(CASE WHEN "version" = '1+11' THEN COALESCE("amount",0) ELSE 0 END),0) * 100)::numeric,2),
NULL, NULL
FROM finance.forecast_data_new
WHERE "Year" = 2026 AND "l8_account" = 'Recurring Revenue'
ORDER BY
CASE row_type WHEN 'summary' THEN 0 WHEN 'customer' THEN 1 ELSE 2 END,
CASE "ruc_risk" WHEN 'RUC' THEN 1 WHEN 'Risk ID' THEN 2 WHEN 'Risk UID' THEN 3 ELSE 4 END ASC,
"attrition_description" ASC, rnk ASC
