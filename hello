    SELECT "l6_description","entity_name","location",
        ROUND((SUM(CASE WHEN "version"='2+10' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS "2+10",
        ROUND((SUM(CASE WHEN "version"='1+11' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS "1+11",
        ROUND(((SUM(CASE WHEN "version"='2+10' THEN COALESCE("amount",0) ELSE 0 END)-
        SUM(CASE WHEN "version"='1+11' THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2) AS "variance"
    FROM finance.forecast_data_new
    WHERE "Year"=(SELECT MAX("Year") FROM finance.forecast_data_new)
    AND "ruc_risk"='RUC'
    AND ("attrition_description" IS NULL OR TRIM("attrition_description")='')
    GROUP BY "l6_description","entity_name","location"
    HAVING SUM(COALESCE("amount",0))<>0
) t
ORDER BY "l6_description", ABS("variance") DESC

