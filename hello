    GROUP BY "EntityName","product_L7_Description","account_L7_Description","location"
    HAVING SUM(COALESCE("amount",0))<>0
) t
ORDER BY "EntityName", "revenue_M" DESC

Example 4 - RUC VARIANCE (GROUP BY product_L6_Description with ruc_risk_attrition filter):
User Question: What is the RUC variance between 1+11 and 2+10?

description_sql:
SELECT * FROM (
    SELECT "product_L6_Description","EntityName","location",
        ROUND((SUM(CASE WHEN "scenario"='2+10' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS "2+10",
        ROUND((SUM(CASE WHEN "scenario"='1+11' THEN COALESCE("amount",0) ELSE 0 END)/1000000.0)::numeric,2) AS "1+11",
        ROUND(((SUM(CASE WHEN "scenario"='2+10' THEN COALESCE("amount",0) ELSE 0 END)-
        SUM(CASE WHEN "scenario"='1+11' THEN COALESCE("amount",0) ELSE 0 END))/1000000.0)::numeric,2) AS "variance"
    FROM finance.forecast_data_updated
    WHERE "year"=(SELECT MAX("year") FROM finance.forecast_data_updated)
    AND "account_L5_Description"='Revenue'
    AND "ruc_risk_attrition"='RUC'
    AND ("attrition_description" IS NULL OR TRIM("attrition_description")='')
    GROUP BY "product_L6_Description","EntityName","location"
    HAVING SUM(COALESCE("amount",0))<>0
) t
ORDER BY "product_L6_Description", ABS("variance") DESC

