ORDER BY sort_key ASC,
CASE "description" WHEN 'RUC' THEN 1 WHEN 'Risk ID' THEN 2 WHEN 'Risk UID' THEN 3 WHEN 'Attrition Provision' THEN 4 WHEN 'Known Attrition' THEN 5 WHEN 'Specific Attrition' THEN 6 ELSE 7 END,
CASE "quarter" WHEN 'Q1' THEN 1 WHEN 'Q2' THEN 2 WHEN 'Q3' THEN 3 WHEN 'Q4' THEN 4 ELSE 5 END

